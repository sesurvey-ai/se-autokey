# copy ไฟล์นี้เป็น .env แล้วใส่ค่าจริง
ISURVEY_USERNAME=
ISURVEY_PASSWORD=
EMCS_USERNAME=
EMCS_PASSWORD=
# สำหรับแจ้งสถานะ "ส่งงานแล้ว" กลับ ISURVEY (se.isurvey.mobi) — ใส่เมื่อจะใช้ --report-isurvey
ISURVEY_REPORT_USER=
ISURVEY_REPORT_PASS=
# บันทึกงานที่ทำเสร็จลงฐานข้อมูลกลาง se-key + ตรวจเลขเซอร์เวย์ซ้ำ (ใส่ทั้งคู่ถึงจะเปิดใช้)
SE_KEY_API_URL=https://key.sesurvey.cloud
SE_KEY_API_KEY=
